# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://username:yourpassword@localhost:27017/askbro?authSource=admin
MONGODB_DB_NAME=
GRIDFS_BUCKET_NAME=

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Cloud:  https://<cluster-id>.<region>.aws.cloud.qdrant.io
# Local:  http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=

# ── Embeddings ────────────────────────────────────────────────────────────────
BGE_MODEL_NAME=BAAI/bge-large-en-v1.5
BGE_RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_BATCH_SIZE=32
# Options: cpu | cuda | mps
EMBEDDING_DEVICE=cpu

# ── LLM ───────────────────────────────────────────────────────────────────────
# Providers: Groq → https://api.groq.com/openai/v1
#            Together → https://api.together.xyz/v1
#            Local vLLM → http://localhost:8000/v1
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=Qwen/Qwen3-32B
LLM_API_KEY=your-llm-api-key
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-hex-string-generated-by-the-command-above
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# ── File upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
